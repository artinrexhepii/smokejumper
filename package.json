{
  "name": "smokejumper",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": { "node": ">=20.9" },
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "dev:dashboard": "pnpm --filter @smokejumper/dashboard dev",
    "chaos": "pnpm --filter @smokejumper/demo chaos",
    "demo:up": "docker compose -f docker-compose.yml -f demo/docker-compose.yml up -d --build",
    "demo:down": "docker compose -f docker-compose.yml -f demo/docker-compose.yml down"
  },
  "devDependencies": {
    "@smokejumper/db": "workspace:*",
    "@smokejumper/plugin-host": "workspace:*",
    "@smokejumper/plugin-sdk": "workspace:*",
    "@smokejumper/registry": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.1.0",
    "tsup": "^8.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.0"
  }
}
