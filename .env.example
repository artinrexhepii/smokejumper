# Smokejumper environment. Get started:
#   cp .env.example .env
#   echo "SMOKEJUMPER_ENCRYPTION_KEY=$(openssl rand -base64 32)" >> .env

# --- required ---
# Envelope-encryption key for plugin credentials (base64, 32 bytes).
# Generate with: openssl rand -base64 32
# SMOKEJUMPER_ENCRYPTION_KEY=

# --- model access ---
# 1 = deterministic offline fake model: the full investigation pipeline runs with
# scripted model responses and needs no API key. Leave FAKE_MODEL empty and set a
# provider key below to get real diagnoses. The provider is auto-detected from
# whichever key you set.
SMOKEJUMPER_FAKE_MODEL=1

# Anthropic (Claude) — the default provider.
ANTHROPIC_API_KEY=

# Google (Gemini) — set this instead to run on Gemini.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# If BOTH keys are set, Anthropic wins. Force the provider explicitly here:
#SMOKEJUMPER_MODEL_PROVIDER=google

# --- optional ---
DASHBOARD_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3400
# Per-stage model overrides (bare model IDs, no provider prefix).
# Pick ONE set below — if you uncomment both, the last-defined values win.
# Anthropic defaults:
#SMOKEJUMPER_TRIAGE_MODEL=claude-haiku-4-5-20251001
#SMOKEJUMPER_INVESTIGATOR_MODEL=claude-sonnet-5
#SMOKEJUMPER_SYNTHESIS_MODEL=claude-sonnet-5
# Gemini defaults:
#SMOKEJUMPER_TRIAGE_MODEL=gemini-2.5-flash
#SMOKEJUMPER_INVESTIGATOR_MODEL=gemini-2.5-pro
#SMOKEJUMPER_SYNTHESIS_MODEL=gemini-2.5-pro

# --- local development outside docker ---
#DATABASE_URL=postgres://smokejumper:smokejumper@localhost:5432/smokejumper
#PORT=3400
